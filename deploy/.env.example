# ── قالب بيئة خدمة المقتنيات (انسخه إلى .env واملأ الأسرار) ──
# لا تضع أسراراً حقيقية في المستودع؛ .env فقط على الخادم.

# المخزن والوسائط
DB_PATH=data/collectibles.db
MEDIA_DIR=data/media
MEDIA_BASE_URL=            # يُضبط عند توفّر النطاق (Phase G)، مثال: https://your-domain

# ربط الخادم الداخلي
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8100

# MRKT
MRKT_API_URL=https://api.tgmrkt.io
MRKT_CDN_URL=https://cdn.tgmrkt.io
MRKT_TIMEOUT=30
MRKT_SALING_COUNT=20      # الحدّ الأقصى لدى MRKT هو 20 — لا تزِده (يُقصَر تلقائياً)

# ── حدود معدّل MRKT (تمنع 429) ──
MRKT_MAX_RPS=1.0          # أقصى طلبات/ثانية. ابدأ بـ 1.0؛ قلّلها إلى 0.5 إن تكرّر 429
MRKT_BURST=1              # عدد الطلبات المسموحة دفعةً واحدة

# ── ترويسات مطابقة للعميل الرسمي (لا تغيّرها إلا لضرورة) ──
MRKT_REFERER=https://cdn.tgmrkt.io/
MRKT_ORIGIN=              # اتركها فارغة (المرجع لا يرسلها)
MRKT_USER_AGENT=
MRKT_AUTH_APP_ID=         # فارغ = null كما في العقد
MRKT_BOT_USERNAME=mrkt
MRKT_APP_SHORT_NAME=app   # اسم الـ Mini App القصير (t.me/mrkt/app)
MRKT_WEBVIEW_URL=

# Telethon (أسرار — املأها على الخادم فقط)
TG_API_ID=
TG_API_HASH=
TG_ASSISTANT_SESSION=

# التسعير / العملة
BINANCE_API_URL=https://api.binance.com
GRAM_SYMBOL=GRAMUSDT
GRAM_PRICE_TTL=60
DEFAULT_COMMISSION_USD=0
CURRENCY_CACHE_TTL=3600
DEFAULT_CURRENCY=USD

# نداء البوت الداخلي (يُفعَّل في مرحلة البوت)
BOT_INTERNAL_URL=http://127.0.0.1:8090
STOREROZ_BOT_TOKEN=          # توكن StoreRozbot للتحقق من initData
INTERNAL_SHARED_SECRET=

# الصمود / المزامنة / السجلّات
RETRY_MAX=3
RETRY_BASE_DELAY=0.5
RETRY_MAX_DELAY=8.0
CB_FAIL_THRESHOLD=5
CB_RESET_TIMEOUT=60
SYNC_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
